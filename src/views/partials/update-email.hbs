 <h6 class="title">Update Email Address</h6>
<form class="section box" action="/settings/updateemail" method="POST">
<div class = "text mb-5">
<p>Enter Your New Email Address Below</p>
</div>
<div class="field is-horizontal">
      <div class="field-body">
        <div class="field">
            <p class = "mb-3">Current Email Address: {{user.email}}</p>
          <input class="input" type="text" placeholder="Enter New Email Address" name="email">
        </div>
      </div>
    </div>
    <button class="button is-link">Submit Change</button>
  </form>
</section>