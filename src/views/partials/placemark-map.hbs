<div id="map" style="height: 400px; width: 100%;"></div>
<script>

  var map = L.map('map').setView([54.5260, 15.2551], 4); L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
  maxZoom: 19, attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>' }).addTo(map);
  /*create new empty bounds object*/ var bounds = new L.LatLngBounds(); /*iterates through coords array and adds marker
  for latitude and longitude at each index*/

  {{#each category.placemarks}}

    var marker = L.marker([{{this.location.lat}},
    {{this.location.lon}}]).addTo(map); /*extend bounds to include all lat and lon values*/
    bounds.extend(marker.getLatLng());

  {{/each}}
  /*fit map to bounds*/ map.fitBounds(bounds);
</script>